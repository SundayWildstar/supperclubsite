---
interface Props {
  variant?: 'hero' | 'mark';
  white?: boolean;
}
const { variant = 'hero', white = false } = Astro.props;
const src = white ? '/white logo.svg' : '/logo.svg';
---

<img
  src={src}
  alt="Supper Club"
  width="595"
  height="842"
  class={`supper-logo ${variant}`}
  decoding="async"
/>

<style>
  .supper-logo {
    display: block;
    width: auto;
    max-width: 80vw;
    object-fit: contain;
  }
  .supper-logo.hero {
    height: clamp(240px, 42vmin, 460px);
    filter: drop-shadow(0 14px 36px rgba(0, 0, 0, 0.55));
  }
  .supper-logo.mark {
    height: clamp(340px, 58vmin, 620px);
    filter: drop-shadow(0 16px 36px rgba(0, 0, 0, 0.6));
  }
</style>
