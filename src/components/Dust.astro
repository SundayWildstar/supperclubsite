---
interface Props {
  count?: number;
}

const { count = 28 } = Astro.props;

function seeded(i: number, salt: number) {
  const x = Math.sin(i * 9301 + salt * 49297) * 233280;
  return x - Math.floor(x);
}

const motes = Array.from({ length: count }, (_, i) => ({
  x: seeded(i, 1) * 100,
  size: 1.2 + seeded(i, 2) * 3.4,
  duration: 22 + seeded(i, 3) * 24,
  delay: -seeded(i, 4) * 40,
  drift: -30 + seeded(i, 5) * 60,
  opacity: 0.25 + seeded(i, 6) * 0.55,
  blur: 0.4 + seeded(i, 7) * 0.6,
}));
---

<div class="dust-field" aria-hidden="true">
  {
    motes.map((m) => (
      <span
        class="mote"
        style={`--x:${m.x}vw; --size:${m.size}px; --duration:${m.duration}s; --delay:${m.delay}s; --drift:${m.drift}px; --op:${m.opacity}; --blur:${m.blur}px;`}
      />
    ))
  }
</div>

<style>
  .dust-field {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 1;
  }

  .mote {
    position: absolute;
    top: 0;
    left: var(--x);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245, 239, 230, 0.9), rgba(245, 239, 230, 0.3) 55%, transparent 100%);
    opacity: 0;
    will-change: transform, opacity;
    animation: fall var(--duration) linear var(--delay) infinite;
  }

  @media (min-width: 768px) and (hover: hover) {
    .mote {
      filter: blur(var(--blur));
    }
  }

  @keyframes fall {
    0% {
      transform: translate3d(0, -12vh, 0);
      opacity: 0;
    }
    8% {
      opacity: var(--op);
    }
    50% {
      transform: translate3d(calc(var(--drift) * 0.5), 50vh, 0);
    }
    92% {
      opacity: var(--op);
    }
    100% {
      transform: translate3d(var(--drift), 112vh, 0);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mote {
      animation: none;
      opacity: 0;
    }
  }
</style>
