---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
---

<Layout title="Supper Club — Enter">
  <a href="/home" class="landing" aria-label="Enter the supper club">
    <div class="landing-center">
      <div class="logo-hover">
        <Logo />
      </div>
      <p class="enter-cue">Click to enter</p>
    </div>
  </a>
</Layout>

<style>
  .landing {
    position: fixed;
    inset: 0;
    display: grid;
    place-items: center;
    cursor: pointer;
    isolation: isolate;
  }

  .landing::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 45%, rgba(201, 169, 110, 0.08), transparent 55%),
      radial-gradient(circle at 15% 85%, rgba(107, 143, 108, 0.08), transparent 60%);
    pointer-events: none;
    z-index: 1;
  }

  .landing-center {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.25rem;
  }

  .logo-hover {
    position: relative;
    isolation: isolate;
  }

  .logo-hover::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 95%;
    height: 80%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      ellipse at center,
      rgba(107, 143, 108, 0.55) 0%,
      rgba(107, 143, 108, 0.25) 40%,
      transparent 72%
    );
    border-radius: 50%;
    filter: blur(4px);
    pointer-events: none;
    z-index: -1;
    animation: green-pulse 4.5s ease-in-out infinite;
  }

  .enter-cue {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: 0.95rem;
    font-style: normal;
    font-weight: 400;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    text-indent: 0.42em;
    color: var(--ink-muted);
    opacity: 0;
    animation:
      fade-in 1.2s ease-out 1.4s forwards,
      breathe 3.2s ease-in-out 2.6s infinite;
  }

  @keyframes green-pulse {
    0%,
    100% {
      opacity: 0.7;
      transform: translate(-50%, -50%) scale(0.92);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.08);
    }
  }

  @keyframes fade-in {
    to {
      opacity: 0.82;
    }
  }

  @keyframes breathe {
    0%,
    100% {
      opacity: 0.82;
    }
    50% {
      opacity: 0.4;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-hover::before {
      animation: none;
    }
    .enter-cue {
      animation: none;
      opacity: 0.82;
    }
  }
</style>
