---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
---

<Layout title="Supper Club — Enter">
  <a href="/home" class="landing" aria-label="Enter the supper club">
    <div class="landing-center">
      <div class="logo-hover">
        <Logo />
      </div>
      <p class="enter-cue">Click to enter</p>
    </div>
  </a>
</Layout>

<style>
  .landing {
    position: fixed;
    inset: 0;
    display: grid;
    place-items: center;
    cursor: pointer;
    isolation: isolate;
  }

  .landing::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #ffffff;
    pointer-events: none;
    z-index: 1;
  }

  .landing-center {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.25rem;
  }

  .enter-cue {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: 0.95rem;
    font-style: normal;
    font-weight: 400;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    text-indent: 0.42em;
    color: rgba(42, 36, 31, 0.78);
    opacity: 0;
    animation:
      fade-in 1.2s ease-out 1.4s forwards,
      breathe 3.2s ease-in-out 2.6s infinite;
  }

  @keyframes fade-in {
    to {
      opacity: 0.82;
    }
  }

  @keyframes breathe {
    0%,
    100% {
      opacity: 0.82;
    }
    50% {
      opacity: 0.4;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .enter-cue {
      animation: none;
      opacity: 0.82;
    }
  }
</style>
