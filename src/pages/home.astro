---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import Dust from '../components/Dust.astro';

const registerUrl = 'https://forms.gle/nNkxtrpV7f1RcJBL7';
---

<Layout title="Supper Club — Metamorphosis">
  <main class="home">
    <Dust count={18} />
    <div class="stack">
      <div class="mark">
        <Logo variant="mark" white />
      </div>
      <h1 class="theme">Metamorphosis</h1>
      <div class="actions">
        <div class="btn-wrap">
          <svg class="btn-vine left" viewBox="0 0 80 40" aria-hidden="true">
            <path class="btn-stem" pathLength="100" d="M 80,20 C 55,24 30,16 0,20" />
            <g class="btn-leaf" style="--leaf-delay: 260ms" transform="translate(57 21) rotate(248)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 400ms" transform="translate(38 20) rotate(112)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 520ms" transform="translate(19 19) rotate(232)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <circle class="btn-bud" cx="0" cy="20" r="1.4" />
          </svg>
          <a class="btn" href={registerUrl} target="_blank" rel="noopener noreferrer">Register</a>
          <svg class="btn-vine right" viewBox="0 0 80 40" aria-hidden="true">
            <path class="btn-stem" pathLength="100" d="M 80,20 C 55,24 30,16 0,20" />
            <g class="btn-leaf" style="--leaf-delay: 260ms" transform="translate(57 21) rotate(248)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 400ms" transform="translate(38 20) rotate(112)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 520ms" transform="translate(19 19) rotate(232)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <circle class="btn-bud" cx="0" cy="20" r="1.4" />
          </svg>
        </div>
        <div class="btn-wrap">
          <svg class="btn-vine left" viewBox="0 0 80 40" aria-hidden="true">
            <path class="btn-stem" pathLength="100" d="M 80,20 C 55,24 30,16 0,20" />
            <g class="btn-leaf" style="--leaf-delay: 260ms" transform="translate(57 21) rotate(248)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 400ms" transform="translate(38 20) rotate(112)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 520ms" transform="translate(19 19) rotate(232)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <circle class="btn-bud" cx="0" cy="20" r="1.4" />
          </svg>
          <a class="btn" href="/menu">Menu</a>
          <svg class="btn-vine right" viewBox="0 0 80 40" aria-hidden="true">
            <path class="btn-stem" pathLength="100" d="M 80,20 C 55,24 30,16 0,20" />
            <g class="btn-leaf" style="--leaf-delay: 260ms" transform="translate(57 21) rotate(248)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 400ms" transform="translate(38 20) rotate(112)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 520ms" transform="translate(19 19) rotate(232)">
              <path class="btn-leaf-shape" d="M 0,0 C 1,-4 7,-5 10,-3 C 8,-1 3,1 0,0 Z" />
            </g>
            <circle class="btn-bud" cx="0" cy="20" r="1.4" />
          </svg>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .home {
    position: relative;
    height: 100dvh;
    overflow: hidden;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto minmax(0, 1fr);
    justify-items: center;
    padding: 1rem;
    text-align: center;
    background:
      linear-gradient(180deg, rgba(11, 20, 15, 0.22) 0%, rgba(5, 10, 7, 0.52) 100%),
      url('/flowers%20background.jfif') center/cover no-repeat,
      #000;
    isolation: isolate;
  }

  .stack {
    display: contents;
  }

  .stack > .mark,
  .stack > .theme,
  .stack > .actions {
    position: relative;
    z-index: 2;
  }

  .stack > .mark {
    align-self: end;
  }

  .stack > .theme {
    align-self: center;
  }

  .stack > .actions {
    align-self: start;
    margin-top: 1rem;
  }

  .mark {
    display: flex;
    justify-content: center;
    margin-bottom: calc(3.75rem - 0.44 * clamp(340px, 62vmin, 720px));
  }

  .theme {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-weight: 300;
    font-style: normal;
    font-size: clamp(2.2rem, 7vw, 5rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1.05;
    color: #f5efe6;
    margin: 0;
    /* compensate for trailing letter-spacing so the word stays optically centered */
    text-indent: 0.18em;
  }

  .actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.85rem;
    width: min(320px, 72vw);
    margin-top: 0.75rem;
  }

  .btn {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: 0.82rem;
    font-weight: 300;
    letter-spacing: 0.62em;
    text-transform: uppercase;
    padding: 1rem 2rem;
    border: 1px solid rgba(245, 239, 230, 0.38);
    color: var(--ink);
    text-align: center;
    transition:
      border-color 320ms ease,
      color 320ms ease,
      background 320ms ease,
      letter-spacing 320ms ease;
  }

  .btn:hover,
  .btn:focus-visible {
    border-color: rgba(245, 239, 230, 0.85);
    color: #ffffff;
    letter-spacing: 0.72em;
    outline: none;
  }

  @media (max-width: 480px) {
    .btn {
      padding: 0.9rem 1.4rem;
      letter-spacing: 0.48em;
    }
    .btn:hover,
    .btn:focus-visible {
      letter-spacing: 0.56em;
    }
  }

  .btn-wrap {
    position: relative;
    display: block;
  }

  .btn-wrap .btn {
    display: block;
    width: 100%;
  }

  .btn-vine {
    position: absolute;
    top: 50%;
    width: 72px;
    height: 36px;
    pointer-events: none;
    opacity: 0;
    overflow: visible;
    transition: opacity 180ms ease;
  }

  .btn-vine.left {
    right: 100%;
    transform: translateY(-50%);
  }

  .btn-vine.right {
    left: 100%;
    transform: translateY(-50%) scaleX(-1);
  }

  .btn-stem {
    fill: none;
    stroke: rgba(63, 95, 65, 0.92);
    stroke-width: 1.05;
    stroke-linecap: round;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.35));
  }

  .btn-leaf-shape {
    fill: rgba(52, 82, 55, 0.92);
    transform: scale(0) rotate(-14deg);
    transform-box: fill-box;
    transform-origin: 0% 50%;
  }

  .btn-bud {
    fill: rgba(201, 169, 110, 0.95);
    stroke: rgba(52, 82, 55, 0.6);
    stroke-width: 0.5;
    transform: scale(0);
    transform-box: fill-box;
    transform-origin: center;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.35));
  }

  .btn-wrap:hover .btn-vine,
  .btn-wrap:focus-within .btn-vine {
    opacity: 1;
  }

  .btn-wrap:hover .btn-stem,
  .btn-wrap:focus-within .btn-stem {
    animation: btn-stem-grow 1200ms cubic-bezier(0.25, 0.5, 0.2, 1) forwards;
  }

  .btn-wrap:hover .btn-leaf-shape,
  .btn-wrap:focus-within .btn-leaf-shape {
    animation: btn-leaf-pop 820ms cubic-bezier(0.22, 0.85, 0.3, 1.05) forwards;
    animation-delay: var(--leaf-delay, 300ms);
  }

  .btn-wrap:hover .btn-bud,
  .btn-wrap:focus-within .btn-bud {
    animation: btn-bud-open 720ms cubic-bezier(0.2, 0.9, 0.3, 1.1) forwards;
    animation-delay: 1020ms;
  }

  @keyframes btn-stem-grow {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes btn-leaf-pop {
    0% {
      transform: scale(0) rotate(-14deg);
    }
    60% {
      transform: scale(1.08) rotate(4deg);
    }
    100% {
      transform: scale(1) rotate(0deg);
    }
  }

  @keyframes btn-bud-open {
    0% {
      transform: scale(0);
    }
    65% {
      transform: scale(1.25);
    }
    100% {
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-vine {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .btn-vine {
      width: 52px;
      height: 26px;
    }
  }

</style>
