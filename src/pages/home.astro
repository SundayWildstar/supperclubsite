---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import Dust from '../components/Dust.astro';

const registerUrl = 'https://forms.gle/nNkxtrpV7f1RcJBL7';
---

<Layout title="Supper Club — Metamorphosis">
  <main class="home">
    <Dust count={30} />
    <div class="stack">
      <div class="mark">
        <Logo variant="mark" white />
        <div class="butterfly-anchor" aria-hidden="true">
          <div class="butterfly">
            <svg class="butterfly-svg" viewBox="-42 -32 84 64">
              <g class="wing wing-left">
                <path class="wing-shape" d="M -3,-4 C -14,-28 -38,-24 -40,-8 C -42,8 -22,14 -3,3 Z" />
                <circle class="wing-spot" cx="-22" cy="-5" r="2.6" />
                <circle class="wing-spot wing-spot-small" cx="-30" cy="2" r="1.3" />
              </g>
              <g class="wing wing-right">
                <path class="wing-shape" d="M 3,-4 C 14,-28 38,-24 40,-8 C 42,8 22,14 3,3 Z" />
                <circle class="wing-spot" cx="22" cy="-5" r="2.6" />
                <circle class="wing-spot wing-spot-small" cx="30" cy="2" r="1.3" />
              </g>
              <ellipse class="body" cx="0" cy="-2" rx="1.3" ry="14" />
              <circle class="head" cx="0" cy="-15" r="2.2" />
              <path class="antenna" d="M -0.5,-16 C -3,-19 -6,-23 -7,-27" />
              <path class="antenna" d="M 0.5,-16 C 3,-19 6,-23 7,-27" />
            </svg>
          </div>
        </div>
      </div>
      <h1 class="theme">Metamorphosis</h1>
      <div class="hairline" aria-hidden="true"></div>
      <div class="actions">
        <div class="btn-wrap">
          <svg class="btn-vine left" viewBox="0 0 120 60" aria-hidden="true">
            <path class="btn-stem" pathLength="100" d="M 120,30 C 85,32 35,6 0,4" />
            <g class="btn-leaf" style="--leaf-delay: 320ms" transform="translate(85 26) rotate(250)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 480ms" transform="translate(56 18) rotate(110)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 620ms" transform="translate(35 11) rotate(225)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <circle class="btn-bud" cx="0" cy="4" r="1.8" />
          </svg>
          <a class="btn" href={registerUrl} target="_blank" rel="noopener noreferrer">Register</a>
          <svg class="btn-vine right" viewBox="0 0 120 60" aria-hidden="true">
            <path class="btn-stem" pathLength="100" d="M 120,30 C 85,32 35,6 0,4" />
            <g class="btn-leaf" style="--leaf-delay: 320ms" transform="translate(85 26) rotate(250)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 480ms" transform="translate(56 18) rotate(110)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 620ms" transform="translate(35 11) rotate(225)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <circle class="btn-bud" cx="0" cy="4" r="1.8" />
          </svg>
        </div>
        <div class="btn-wrap">
          <svg class="btn-vine left" viewBox="0 0 120 60" aria-hidden="true">
            <path class="btn-stem" pathLength="100" d="M 120,30 C 85,32 35,6 0,4" />
            <g class="btn-leaf" style="--leaf-delay: 320ms" transform="translate(85 26) rotate(250)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 480ms" transform="translate(56 18) rotate(110)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 620ms" transform="translate(35 11) rotate(225)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <circle class="btn-bud" cx="0" cy="4" r="1.8" />
          </svg>
          <a class="btn" href="/menu">Menu</a>
          <svg class="btn-vine right" viewBox="0 0 120 60" aria-hidden="true">
            <path class="btn-stem" pathLength="100" d="M 120,30 C 85,32 35,6 0,4" />
            <g class="btn-leaf" style="--leaf-delay: 320ms" transform="translate(85 26) rotate(250)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 480ms" transform="translate(56 18) rotate(110)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <g class="btn-leaf" style="--leaf-delay: 620ms" transform="translate(35 11) rotate(225)">
              <path class="btn-leaf-shape" d="M 0,0 C 2,-6 10,-7 14,-4 C 11,-1 4,2 0,0 Z" />
            </g>
            <circle class="btn-bud" cx="0" cy="4" r="1.8" />
          </svg>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .home {
    position: relative;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 3rem 1.5rem;
    background:
      linear-gradient(180deg, rgba(11, 20, 15, 0.22) 0%, rgba(5, 10, 7, 0.52) 100%),
      url('/flowers%20background.jfif') center/cover no-repeat,
      var(--bg-dark);
    isolation: isolate;
  }

  .stack {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    text-align: center;
  }

  .stack > .mark,
  .stack > .theme,
  .stack > .actions {
    opacity: 0;
    transform: translateY(28px);
    animation: enter 1.4s cubic-bezier(0.22, 0.68, 0.2, 1) forwards;
  }

  .stack > .mark {
    animation-delay: 180ms;
  }

  .stack > .theme {
    animation-delay: 560ms;
  }

  .stack > .actions {
    animation-delay: 960ms;
  }

  @keyframes enter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stack > .mark,
    .stack > .theme,
    .stack > .actions {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  .mark {
    position: relative;
    display: flex;
    justify-content: center;
    margin-bottom: -5.25rem;
    isolation: isolate;
  }

  .mark::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 72%;
    height: 56%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      rgba(5, 10, 7, 0.5) 0%,
      rgba(5, 10, 7, 0.28) 45%,
      transparent 76%
    );
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    -webkit-mask-image: radial-gradient(ellipse at center, black 28%, transparent 70%);
    mask-image: radial-gradient(ellipse at center, black 28%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  .theme {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-weight: 300;
    font-style: normal;
    font-size: clamp(2.2rem, 7vw, 5rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1.05;
    color: #f5efe6;
    margin: 0;
    /* compensate for trailing letter-spacing so the word stays optically centered */
    text-indent: 0.18em;
  }

  .hairline {
    width: min(260px, 60vw);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(245, 239, 230, 0.42), transparent);
    margin: 0.25rem 0 0.5rem;
  }

  .actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.85rem;
    width: min(320px, 72vw);
    margin-top: 0.75rem;
  }

  .btn {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: 0.82rem;
    font-weight: 300;
    letter-spacing: 0.62em;
    text-transform: uppercase;
    padding: 1rem 2rem;
    border: 1px solid rgba(245, 239, 230, 0.38);
    color: var(--ink);
    text-align: center;
    transition:
      border-color 320ms ease,
      color 320ms ease,
      background 320ms ease,
      letter-spacing 320ms ease;
  }

  .btn:hover,
  .btn:focus-visible {
    border-color: rgba(245, 239, 230, 0.85);
    color: #ffffff;
    letter-spacing: 0.72em;
    outline: none;
  }

  @media (max-width: 480px) {
    .btn {
      padding: 0.9rem 1.4rem;
      letter-spacing: 0.48em;
    }
    .btn:hover,
    .btn:focus-visible {
      letter-spacing: 0.56em;
    }
  }

  .btn-wrap {
    position: relative;
    display: block;
  }

  .btn-wrap .btn {
    display: block;
    width: 100%;
  }

  .btn-vine {
    position: absolute;
    top: 50%;
    width: 110px;
    height: 56px;
    pointer-events: none;
    opacity: 0;
    overflow: visible;
    transition: opacity 180ms ease;
  }

  .btn-vine.left {
    right: 100%;
    transform: translateY(-50%);
  }

  .btn-vine.right {
    left: 100%;
    transform: translateY(-50%) scaleX(-1);
  }

  .btn-stem {
    fill: none;
    stroke: rgba(63, 95, 65, 0.92);
    stroke-width: 1.05;
    stroke-linecap: round;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.35));
  }

  .btn-leaf-shape {
    fill: rgba(52, 82, 55, 0.92);
    transform: scale(0) rotate(-14deg);
    transform-box: fill-box;
    transform-origin: 0% 50%;
  }

  .btn-bud {
    fill: rgba(201, 169, 110, 0.95);
    stroke: rgba(52, 82, 55, 0.6);
    stroke-width: 0.5;
    transform: scale(0);
    transform-box: fill-box;
    transform-origin: center;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.35));
  }

  .btn-wrap:hover .btn-vine,
  .btn-wrap:focus-within .btn-vine {
    opacity: 1;
  }

  .btn-wrap:hover .btn-stem,
  .btn-wrap:focus-within .btn-stem {
    animation: btn-stem-grow 1200ms cubic-bezier(0.25, 0.5, 0.2, 1) forwards;
  }

  .btn-wrap:hover .btn-leaf-shape,
  .btn-wrap:focus-within .btn-leaf-shape {
    animation: btn-leaf-pop 820ms cubic-bezier(0.22, 0.85, 0.3, 1.05) forwards;
    animation-delay: var(--leaf-delay, 300ms);
  }

  .btn-wrap:hover .btn-bud,
  .btn-wrap:focus-within .btn-bud {
    animation: btn-bud-open 720ms cubic-bezier(0.2, 0.9, 0.3, 1.1) forwards;
    animation-delay: 1020ms;
  }

  @keyframes btn-stem-grow {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes btn-leaf-pop {
    0% {
      transform: scale(0) rotate(-14deg);
    }
    60% {
      transform: scale(1.08) rotate(4deg);
    }
    100% {
      transform: scale(1) rotate(0deg);
    }
  }

  @keyframes btn-bud-open {
    0% {
      transform: scale(0);
    }
    65% {
      transform: scale(1.25);
    }
    100% {
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-vine {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .btn-vine {
      width: 72px;
      height: 40px;
    }
  }

  .butterfly-anchor {
    position: absolute;
    top: 22%;
    left: 50%;
    width: clamp(48px, 7vmin, 78px);
    height: auto;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 3;
  }

  .butterfly {
    opacity: 0;
    animation: fly-in 4.6s cubic-bezier(0.3, 0.55, 0.25, 1) 2500ms forwards;
  }

  .butterfly-svg {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
    filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.45));
  }

  .wing {
    transform-box: fill-box;
  }

  .wing-left {
    transform-origin: 100% 50%;
    animation:
      flap-fast 220ms ease-in-out 2500ms 21 both,
      flap-slow 2s ease-in-out 7120ms infinite;
  }

  .wing-right {
    transform-origin: 0% 50%;
    animation:
      flap-fast 220ms ease-in-out 2500ms 21 both,
      flap-slow 2s ease-in-out 7120ms infinite;
  }

  .wing-shape {
    fill: #d7a6a1;
  }

  .wing-spot {
    fill: #c9a96e;
  }

  .wing-spot-small {
    fill: #b9a7cf;
  }

  .body,
  .head {
    fill: #2a241f;
  }

  .antenna {
    fill: none;
    stroke: #2a241f;
    stroke-width: 0.7;
    stroke-linecap: round;
  }

  @keyframes fly-in {
    0% {
      transform: translate(-26vw, -36vh) scale(0.45) rotate(-22deg);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    28% {
      transform: translate(-12vw, -20vh) scale(0.62) rotate(12deg);
      opacity: 1;
    }
    50% {
      transform: translate(2vw, -10vh) scale(0.78) rotate(-10deg);
    }
    72% {
      transform: translate(6vw, -3vh) scale(0.92) rotate(6deg);
    }
    90% {
      transform: translate(-1vw, 0.6vh) scale(1.02) rotate(-2deg);
    }
    100% {
      transform: translate(0, 0) scale(1) rotate(0deg);
      opacity: 1;
    }
  }

  @keyframes flap-fast {
    0%,
    100% {
      transform: scaleX(1);
    }
    50% {
      transform: scaleX(0.25);
    }
  }

  @keyframes flap-slow {
    0%,
    100% {
      transform: scaleX(1);
    }
    50% {
      transform: scaleX(0.62);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .butterfly {
      opacity: 1;
      animation: none;
    }
    .wing-left,
    .wing-right {
      animation: none;
    }
  }
</style>
