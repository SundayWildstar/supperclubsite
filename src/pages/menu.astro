---
import Layout from '../layouts/Layout.astro';

const courses = ['I', 'II', 'III', 'IV', 'V', 'VI'];
---

<Layout title="Supper Club — The Menu" tone="light">
  <main class="menu">
    <div class="menu-inner">
      <header class="menu-header">
        <h1 class="theme">Metamorphosis</h1>
      </header>

      <section class="paper">
        {
          courses.map((num) => (
            <article class="course">
              <p class="course-label">Course {num}</p>
              <span class="course-mark" aria-label="To be revealed">?</span>
            </article>
          ))
        }
      </section>

      <a class="menu-back" href="/home">&larr; Back</a>
    </div>
  </main>
</Layout>

<style>
  .menu {
    min-height: 100vh;
    position: relative;
    padding: 4rem 1.5rem 5rem;
    isolation: isolate;
    background:
      linear-gradient(180deg, rgba(251, 246, 237, 0.55) 0%, rgba(246, 236, 238, 0.65) 100%),
      url('/menu%20background.jpg') center/cover no-repeat;
  }

  .menu-inner {
    position: relative;
    z-index: 2;
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    align-items: center;
  }

  .menu-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .theme {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-weight: 300;
    font-style: normal;
    font-size: clamp(2.2rem, 7vw, 5rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1.05;
    color: var(--ink-dark);
    margin: 0;
    text-indent: 0.18em;
  }

  .paper {
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(42, 36, 31, 0.12);
    border-radius: 2px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 24px 60px -30px rgba(42, 36, 31, 0.45);
    padding: 2.5rem 2.75rem;
    width: 100%;
    max-width: 520px;
    display: flex;
    flex-direction: column;
  }

  .course {
    padding: 1.5rem 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    border-bottom: 1px solid rgba(42, 36, 31, 0.1);
  }

  .course:first-child {
    padding-top: 0.25rem;
  }

  .course:last-child {
    padding-bottom: 0.25rem;
    border-bottom: none;
  }

  .course-label {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: 1.1rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.04em;
    text-transform: none;
    color: var(--ink-dark);
    line-height: 1.1;
  }

  .course-mark {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 3.25rem;
    line-height: 1;
    color: var(--ink-dark);
    opacity: 0.55;
  }

  .menu-back {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: var(--ink-dark-muted);
    padding: 0.8rem 1.4rem;
    border-bottom: 1px solid transparent;
    transition: color 260ms ease, border-color 260ms ease;
  }

  .menu-back:hover,
  .menu-back:focus-visible {
    color: var(--ink-dark);
    border-color: rgba(42, 36, 31, 0.35);
    outline: none;
  }

  @media (max-width: 480px) {
    .paper {
      padding: 2rem 1.5rem;
    }
  }
</style>
