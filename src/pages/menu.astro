---
import Layout from '../layouts/Layout.astro';
import Vines from '../components/Vines.astro';

const courses = ['I', 'II', 'III', 'IV', 'V', 'VI'];
---

<Layout title="Supper Club — The Menu" tone="light">
  <main class="menu">
    <Vines tone="light" />
    <div class="menu-inner">
      <header class="menu-header">
        <p class="eyebrow">Metamorphosis</p>
        <h1>The Menu</h1>
        <div class="hairline" aria-hidden="true"></div>
        <p class="teaser">Six courses. Unveiled soon.</p>
      </header>

      <div class="courses">
        {
          courses.map((num) => (
            <article class="course">
              <p class="course-label">Course {num}</p>
              <span class="course-mark" aria-label="To be revealed">?</span>
            </article>
          ))
        }
      </div>

      <a class="menu-back" href="/home">&larr; Back</a>
    </div>
  </main>
</Layout>

<style>
  .menu {
    min-height: 100vh;
    position: relative;
    padding: 4rem 1.5rem 5rem;
    isolation: isolate;
  }

  .menu-inner {
    position: relative;
    z-index: 2;
    max-width: 920px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .menu-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .menu-header h1 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(2.75rem, 7vw, 4.5rem);
    letter-spacing: 0.01em;
    color: var(--ink-dark);
  }

  .hairline {
    width: 180px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(42, 36, 31, 0.35), transparent);
  }

  .teaser {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.05rem;
    color: var(--ink-dark-muted);
  }

  .courses {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .course {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(42, 36, 31, 0.08);
    border-radius: 2px;
    padding: 2.4rem 1.25rem 2.6rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    transition: transform 420ms ease, box-shadow 420ms ease, border-color 420ms ease;
    position: relative;
    overflow: hidden;
  }

  .course::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(215, 166, 161, 0.08), rgba(185, 167, 207, 0.08));
    opacity: 0;
    transition: opacity 420ms ease;
  }

  .course:hover {
    transform: translateY(-3px);
    border-color: rgba(185, 167, 207, 0.55);
    box-shadow: 0 14px 30px -18px rgba(42, 36, 31, 0.3);
  }

  .course:hover::before {
    opacity: 1;
  }

  .course-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--ink-dark-muted);
    position: relative;
  }

  .course-mark {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 4rem;
    line-height: 1;
    color: var(--ink-dark);
    opacity: 0.55;
    position: relative;
  }

  .menu-back {
    align-self: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: var(--ink-dark-muted);
    padding: 0.8rem 1.4rem;
    border-bottom: 1px solid transparent;
    transition: color 260ms ease, border-color 260ms ease;
  }

  .menu-back:hover,
  .menu-back:focus-visible {
    color: var(--ink-dark);
    border-color: rgba(42, 36, 31, 0.35);
    outline: none;
  }

  @media (max-width: 720px) {
    .courses {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 420px) {
    .courses {
      grid-template-columns: 1fr;
    }
  }
</style>
