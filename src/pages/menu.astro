---
import Layout from '../layouts/Layout.astro';

const courses = ['I', 'II', 'III', 'IV', 'V', 'VI'];
---

<Layout title="Supper Club — The Menu" tone="dark">
  <main class="menu">
    <div class="menu-inner">
      <h1 class="theme">Metamorphosis</h1>

      <section class="paper">
        {
          courses.map((num) => (
            <article class="course">
              <p class="course-label">Course {num}</p>
              <span class="course-mark" aria-label="To be revealed">?</span>
            </article>
          ))
        }
      </section>

      <a class="menu-back" href="/home">&larr; Back</a>
    </div>
  </main>
</Layout>

<style>
  .menu {
    height: 100dvh;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    padding: 1.25rem 1rem;
    isolation: isolate;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(ellipse at center, transparent 45%, rgba(0, 0, 0, 0.45) 100%),
      url('/menu%20background.jpg') center/cover no-repeat,
      #000;
  }

  .menu-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 360px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }

  .theme {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-weight: 300;
    font-style: normal;
    font-size: clamp(1.5rem, 4.2vw, 2.2rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1.05;
    color: #f5efe6;
    margin: 0;
    text-indent: 0.18em;
    text-align: center;
  }

  .paper {
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(42, 36, 31, 0.14);
    border-radius: 2px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.55) inset,
      0 18px 48px -24px rgba(0, 0, 0, 0.65);
    padding: 0.9rem 1.5rem;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .course {
    padding: 0.45rem 0;
    text-align: center;
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: center;
    gap: 0.6rem;
    border-bottom: 1px solid rgba(42, 36, 31, 0.08);
  }

  .course:last-child {
    border-bottom: none;
  }

  .course-label {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: 0.95rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.04em;
    color: var(--ink-dark);
    line-height: 1.1;
  }

  .course-mark {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.2rem;
    line-height: 1;
    color: var(--ink-dark);
    opacity: 0.55;
  }

  .menu-back {
    font-family: 'Inter', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: rgba(245, 239, 230, 0.7);
    padding: 0.35rem 0.9rem;
    border-bottom: 1px solid transparent;
    transition:
      color 260ms ease,
      border-color 260ms ease;
  }

  .menu-back:hover,
  .menu-back:focus-visible {
    color: #fff;
    border-color: rgba(245, 239, 230, 0.45);
    outline: none;
  }
</style>
